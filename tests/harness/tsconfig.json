{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"lib": ["ES2020"],
		"outDir": "./dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"moduleResolution": "nodenext"
	},
	"ts-node": {
		"esm": false,
		"transpileOnly": true
	},
	"include": ["*.ts"],
	"exclude": ["node_modules"]
}
